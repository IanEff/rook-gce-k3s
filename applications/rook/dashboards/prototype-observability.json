{
  "uid": "prototype-obs-v1",
  "title": "PROTOTYPE-Observability Dashboard",
  "tags": ["prototype", "slo", "ceph", "observability"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "1m",
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Is the cluster healthy right now? — Overview",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "type": "stat",
      "id": 1,
      "title": "Cluster Health Status",
      "description": "0=Green, 1=Yellow, 2=Red. They're currently running on ceph -s to get this.",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "HEALTH_OK", "color": "green", "index": 0 } } },
            { "type": "value", "options": { "1": { "text": "HEALTH_WARN", "color": "yellow", "index": 1 } } },
            { "type": "value", "options": { "2": { "text": "HEALTH_ERR", "color": "red", "index": 2 } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      },
      "targets": [{ "expr": "ceph_health_status", "legendFormat": "Health", "refId": "A" }]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "OSDs Up vs Total",
      "description": "Single number, should be 1.0. When it isn't, they want to know before Claude does.",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green", "value": 1.0 }
            ]
          }
        }
      },
      "targets": [{ "expr": "count(ceph_osd_up == 1) / count(ceph_osd_up)", "legendFormat": "Up ratio", "refId": "A" }]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "PGs not Active+Clean",
      "description": "Zero is good. Any number here means something is recovering, backfilling, or inconsistent.",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [{ "expr": "ceph_pg_total - ceph_pg_active - ceph_pg_clean", "legendFormat": "Unhealthy PGs", "refId": "A" }]
    },
    {
      "type": "gauge",
      "id": 4,
      "title": "Capacity Used %",
      "description": "Hard threshold lines at 75% (warn) and 80% (critical).",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      },
      "targets": [{ "expr": "ceph_cluster_total_used_bytes / ceph_cluster_total_bytes * 100", "legendFormat": "Used %", "refId": "A" }]
    },
    {
      "type": "row",
      "id": 200,
      "title": "How fast is it and is it getting slower? — SLI layer",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }
    },
    {
      "type": "timeseries",
      "id": 5,
      "title": "OSD Write Latency AVG",
      "description": "The tick ingest proxy. Average latency of OSD write operations. Red line = 50ms warning.",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "thresholdsStyle": { "mode": "line" } },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.05 }] }
        }
      },
      "targets": [{ "expr": "sum(rate(ceph_osd_op_w_latency_sum[5m])) / sum(rate(ceph_osd_op_w_latency_count[5m]))", "legendFormat": "Write Avg", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "OSD Read Latency AVG",
      "description": "The simulation read proxy. Average latency of OSD read operations. Red line = 50ms warning.",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "thresholdsStyle": { "mode": "line" } },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.05 }] }
        }
      },
      "targets": [{ "expr": "sum(rate(ceph_osd_op_r_latency_sum[5m])) / sum(rate(ceph_osd_op_r_latency_count[5m]))", "legendFormat": "Read Avg", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "id": 12,
      "title": "OSD Write Latency P99 (Native Histogram)",
      "description": "Calculated from OSD 2D histograms. True tail latency for quants.",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "thresholdsStyle": { "mode": "line" } },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.05 }] }
        }
      },
      "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(ceph_native_osd_op_w_latency_seconds_bucket[5m])) by (le))", "legendFormat": "Write P99", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "id": 13,
      "title": "OSD Read Latency P99 (Native Histogram)",
      "description": "Calculated from OSD 2D histograms. True tail latency for simulations.",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "thresholdsStyle": { "mode": "line" } },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.05 }] }
        }
      },
      "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(ceph_native_osd_op_r_latency_seconds_bucket[5m])) by (le))", "legendFormat": "Read P99", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "id": 7,
      "title": "BlueStore KV Sync Latency (Leading Indicator)",
      "description": "Metadata commit to RocksDB. Sub-ms on enterprise NVMe.",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [{ "expr": "rate(ceph_bluestore_kv_sync_lat_sum[5m]) / rate(ceph_bluestore_kv_sync_lat_count[5m])", "legendFormat": "KV Sync Latency", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "Network Throughput per Node (NIC canary)",
      "description": "Overlay across nodes. Approaching 1.25 GB/s shows congestion.",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [{ "expr": "rate(node_network_receive_bytes_total{device=~\"eth.*|en.*\"}[5m])", "legendFormat": "{{instance}}", "refId": "A" }]
    },
    {
      "type": "row",
      "id": 300,
      "title": "Are we burning through our reliability budget? — SLO layer",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 1 }
    },
    {
      "type": "stat",
      "id": 9,
      "title": "Recent Slow Writes (>100ms)",
      "description": "Rate of write operations exceeding the 100ms SLO threshold.",
      "gridPos": { "x": 0, "y": 31, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [{ "expr": "sum(rate(ceph_osd_op_w_latency_count{job=\"ceph-latency-bridge\"}[1m])) - sum(rate(ceph_osd_op_w_latency_bucket{job=\"ceph-latency-bridge\",le=\"102.399999\"}[1m]))", "legendFormat": "Slow Writes/s", "refId": "A" }]
    },
    {
      "type": "stat",
      "id": 14,
      "title": "Read SLO Success Rate (Ops < 100ms)",
      "description": "% of read operations meeting the 100ms latency target (OSD hardware limit).",
      "gridPos": { "x": 8, "y": 31, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      },
      "targets": [{ "expr": "sum(rate(ceph_native_osd_op_r_latency_seconds_bucket{job=\"ceph-latency-bridge\",le=\"102.399999\"}[5m])) / sum(rate(ceph_native_osd_op_r_latency_seconds_count{job=\"ceph-latency-bridge\"}[5m]))", "legendFormat": "Success Rate", "refId": "A" }]
    },
    {
      "type": "stat",
      "id": 15,
      "title": "Write SLO Success Rate (Ops < 100ms)",
      "description": "% of write operations meeting the 100ms latency target (OSD hardware limit).",
      "gridPos": { "x": 16, "y": 31, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      },
      "targets": [{ "expr": "sum(rate(ceph_native_osd_op_w_latency_seconds_bucket{job=\"ceph-latency-bridge\",le=\"102.399999\"}[5m])) / sum(rate(ceph_native_osd_op_w_latency_seconds_count{job=\"ceph-latency-bridge\"}[5m]))", "legendFormat": "Success Rate", "refId": "A" }]
    },
    {
      "type": "stat",
      "id": 10,
      "title": "OSD Read Performance Index",
      "description": "Current Avg Read Latency relative to 50ms target. 1.0 = on target, >1.0 = failing target.",
      "gridPos": { "x": 0, "y": 35, "w": 12, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      },
      "targets": [{ "expr": "(sum(rate(ceph_osd_op_r_latency_sum[5m])) / sum(rate(ceph_osd_op_r_latency_count[5m]))) / 0.05", "legendFormat": "Index", "refId": "A" }]
    },
    {
      "type": "stat",
      "id": 11,
      "title": "OSD Write Performance Index",
      "description": "Current Avg Write Latency relative to 50ms target. 1.0 = on target, >1.0 = failing target.",
      "gridPos": { "x": 12, "y": 35, "w": 12, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      },
      "targets": [{ "expr": "(sum(rate(ceph_osd_op_w_latency_sum[5m])) / sum(rate(ceph_osd_op_w_latency_count[5m]))) / 0.05", "legendFormat": "Index", "refId": "A" }]
    }
  ]
}
